services:
  grafana:
    image: "{{ grafana_image | default('grafana/grafana-oss:latest') }}"
    container_name: grafana
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: "{{ grafana_admin_user | default('admin') }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password }}"
      GF_FEATURE_TOGGLES_ENABLE: "provisioning,kubernetesDashboards"
    ports:
      - "{{ grafana_bind_address | default('127.0.0.1') }}:{{ grafana_port | default(3000) }}:3000"
    volumes:
      - grafana_data:/var/lib/grafana
      - {{ grafana_provisioning_dir | default('/opt/grafana/provisioning') }}:/etc/grafana/provisioning:ro
      - {{ grafana_dashboards_host_dir | default('/opt/grafana/repo/grafana') }}:/opt/dashboards:ro
    healthcheck:
      test: ["CMD-SHELL", "curl -fs http://localhost:3000/api/health | grep -q 'ok' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - {{ docker_shared_network | default('infra') }}

volumes:
  grafana_data:

networks:
  {{ docker_shared_network | default('infra') }}:
    external: true

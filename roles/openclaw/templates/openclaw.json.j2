{
  "meta": {
    "lastTouchedVersion": "2026.3.28"
  },
  "auth": {
    "profiles": {
{% if openclaw_github_copilot_enabled | bool %}
      "github-copilot:github": {
        "provider": "github-copilot",
        "mode": "token"
      }
{% endif %}
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "{{ openclaw_model_primary }}"
      },
      "models": {
        "{{ openclaw_model_primary }}": {}
      },
      "workspace": "{{ openclaw_workspace }}"
    }
  },
  "tools": {
    "profile": "{{ openclaw_tools_profile }}"
  },
  "commands": {
    "native": "{{ openclaw_commands_native }}",
    "nativeSkills": "{{ openclaw_commands_native_skills }}",
    "restart": {{ openclaw_commands_restart | bool | to_json }},
    "ownerDisplay": "{{ openclaw_commands_owner_display }}"
  },
  "session": {
    "dmScope": "{{ openclaw_session_dm_scope }}"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": {{ openclaw_hooks_boot_md | bool | to_json }}
        },
        "bootstrap-extra-files": {
          "enabled": {{ openclaw_hooks_bootstrap_extra_files | bool | to_json }}
        },
        "command-logger": {
          "enabled": {{ openclaw_hooks_command_logger | bool | to_json }}
        },
        "session-memory": {
          "enabled": {{ openclaw_hooks_session_memory | bool | to_json }}
        }
      }
    }
  },
  "channels": {
{% if openclaw_msteams_enabled | bool %}
    "msteams": {
      "enabled": true,
      "appId": "{{ openclaw_msteams_app_id }}",
      "appPassword": "{{ openclaw_msteams_app_password }}",
      "tenantId": "{{ openclaw_msteams_tenant_id }}",
      "dmPolicy": "{{ openclaw_msteams_dm_policy }}",
      "groupPolicy": "{{ openclaw_msteams_group_policy }}",
      "teams": {}
    }
{% endif %}
  },
  "gateway": {
    "port": {{ openclaw_gateway_port }},
    "mode": "{{ openclaw_gateway_mode }}",
    "bind": "{{ openclaw_gateway_bind }}",
    "auth": {
      "mode": "token",
      "token": "{{ openclaw_gateway_auth_token }}"
    },
    "tailscale": {
      "mode": "{{ openclaw_tailscale_mode }}",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": {{ openclaw_gateway_deny_commands | to_json }}
    }
  },
  "plugins": {
    "entries": {
{% if openclaw_msteams_enabled | bool %}
      "msteams": {
        "enabled": true
      }
{% endif %}
    }
  }
}

services:
  marketing-display:
    build:
      context: .
      dockerfile: Dockerfile
    image: "{{ marketing_display_image }}"
    container_name: marketing_display
    restart: unless-stopped
    environment:
      DB_HOST: "{{ marketing_display_db_host }}"
      DB_PORT: "{{ marketing_display_db_port }}"
      DB_NAME: "{{ marketing_display_db_name }}"
      DB_USER: "{{ marketing_display_db_user }}"
      DB_PASS: "{{ marketing_display_db_pass }}"
      CACHE_TTL_SECONDS: "{{ marketing_display_cache_ttl }}"
    ports:
      - "{{ marketing_display_bind_address }}:{{ marketing_display_port }}:8000"
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request,sys; r=urllib.request.urlopen('http://localhost:8000/health',timeout=4); sys.exit(0 if r.status==200 else 1)\""]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    networks:
      - {{ docker_shared_network | default('infra') }}

networks:
  {{ docker_shared_network | default('infra') }}:
    external: true
